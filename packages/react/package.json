{
  "name": "@sansu-ui/react",
  "version": "0.1.0",
  "description": "Modern React UI Component Library",
  "author": "Sanskar Amle",
  "license": "MIT",
  "homepage": "https://github.com/sanskar-commits/sansu-ui",
  "repository": {
    "type": "git",
    "url": "https://github.com/sanskar-commits/sansu-ui.git"
  },
  "bugs": {
    "url": "https://github.com/sanskar-commits/sansu-ui/issues"
  },
  "keywords": [
    "react",
    "typescript",
    "ui",
    "component-library",
    "design-system",
    "tailwindcss",
    "sansu-ui"
  ],
  "private": false,
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.0"
  }
}